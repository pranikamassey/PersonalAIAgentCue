{
  "name": "buddy-extension",
  "displayName": "Buddy",
  "version": "0.1.0",
  "description": "AI personal assistant living in your Chrome side panel",
  "author": "pranika",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.18.10",
    "@plasmohq/storage": "^1.11.0",
    "lottie-react": "^2.4.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "storage",
      "alarms",
      "notifications",
      "sidePanel",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "action": {
      "default_title": "Open Buddy"
    }
  }
}
